{
  "name": "3-minutes-fake-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:pwa": "pnpm --filter pwa dev",
    "build:pwa": "pnpm --filter pwa build",
    "build:android": "CAPACITOR=1 VITE_WS_URL=wss://three-minutes-ws.fly.dev pnpm --filter pwa build && pnpm cap:sync",
    "deploy": "pnpm --filter pwa deploy",
    "dev:controller": "pnpm --filter controller dev",
    "build:controller": "pnpm --filter controller build",
    "dev:server": "pnpm --filter server dev",
    "dev:remote": "pnpm --parallel --stream --filter controller --filter server run dev",
    "cap:sync": "pnpm --filter pwa exec cap sync android",
    "cap:open": "pnpm --filter pwa exec cap open android",
    "apk:distribute": "firebase appdistribution:distribute pwa/android/app/build/outputs/apk/debug/app-debug.apk --app 1:881863467694:android:e4bec967f86651b594033f --groups 3-minuten-dreh"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "devDependencies": {
    "firebase-tools": "^15.14.0"
  }
}
